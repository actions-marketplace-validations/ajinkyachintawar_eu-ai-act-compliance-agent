# Groq — all LLM inference (compliance graph + code scanner)
# Free tier at https://console.groq.com
GROQ_API_KEY=gsk_your-groq-key-here

# NVIDIA NIM — used only for nv-embed-v1 embeddings (RAG retrieval)
# Free credits at https://build.nvidia.com
NIM_API_KEY_EMBED=nvapi-your-embedding-key-here

# Supabase — vector DB for RAG chunks
# Create a project at https://supabase.com (EU region recommended)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-anon-key-here

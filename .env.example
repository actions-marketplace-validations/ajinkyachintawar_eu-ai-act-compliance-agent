# NVIDIA NIM — get a free key at https://build.nvidia.com
NIM_API_KEY_INFERENCE=nvapi-your-inference-key-here
NIM_API_KEY_EMBED=nvapi-your-embedding-key-here

# Groq — fast inference for code scanner, get a free key at https://console.groq.com
GROQ_API_KEY=gsk_your-groq-key-here

# Supabase — create a project at https://supabase.com (EU region recommended)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-anon-key-here
